{
  "name": "basedocs",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 5070",
    "server": "cd server && npx ts-node-esm index.ts",
    "dev:full": "concurrently \"pnpm dev\" \"pnpm server\"",
    "build": "vite build && cd server && pnpm install && pnpm build",
    "start": "cd server && node_modules/.bin/prisma migrate deploy && node dist/index.js",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:seed": "npx ts-node --esm prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "@tiptap/extension-placeholder": "^2.4.0",
    "@tiptap/pm": "^2.4.0",
    "@tiptap/react": "^2.4.0",
    "@tiptap/starter-kit": "^2.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.24.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "prisma": "^5.16.0",
    "typescript": "^5.5.3",
    "vite": "^5.3.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  }
}
